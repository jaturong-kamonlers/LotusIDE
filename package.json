{
  "name": "lotus-ide",
  "version": "1.8.0",
  "description": "Lotus ArduiBot IDE - Learning by Doing",
  "author": "Jaturong Kamonlers <jaturong9999@gmail.com>",
  "homepage": "https://github.com/jaturong-kamonlers/LotusIDE-Releases",
  "repository": {
    "type": "git",
    "url": "https://github.com/jaturong-kamonlers/LotusIDE.git"
  },
  "license": "SEE LICENSE IN LICENSE",
  "main": "electron/main.js",
  "scripts": {
    "dev": "node scripts/kill-electron.js && concurrently -k \"npm run vite\" \"npm run electron:dev\"",
    "kill": "node scripts/kill-electron.js && npx kill-port 5173",
    "vite": "vite",
    "electron:dev": "wait-on http://localhost:5173 && electron .",
    "build": "vite build && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "@mdi/js": "^7.4.47",
    "blockly": "^10.4.3",
    "electron-updater": "^6.8.3",
    "jszip": "^3.10.1",
    "pinia": "^2.1.7",
    "serialport": "^12.0.0",
    "vue": "^3.4.0",
    "vuetify": "^3.6.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "concurrently": "^8.2.2",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0",
    "kill-port": "^2.0.1",
    "vite": "^5.2.0",
    "vite-plugin-vuetify": "^2.0.3",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.lotus-arduibot.ide",
    "productName": "Lotus IDE",
    "asar": true,
    "asarUnpack": [
      "node_modules/serialport/**",
      "node_modules/@serialport/**",
      "node_modules/node-gyp-build/**",
      "node_modules/bindings/**",
      "drivers/**",
      "public/boards/**"
    ],
    "compression": "store",
    "publish": {
      "provider": "github",
      "owner": "jaturong-kamonlers",
      "repo": "LotusIDE-Releases"
    },
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "shared/**/*",
      "public/boards/**/*",
      "public/icons/**/*",
      "public/logo/**/*",
      "sounds/**/*",
      "drivers/**/*",
      "LICENSE",
      "THIRD-PARTY-NOTICES.md"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "app/resources",
        "filter": [
          "**/*",
          "!arduino-cli/staging${/*}",
          "!arduino-cli/staging"
        ]
      },
      {
        "from": "build/linux/99-lotus.rules",
        "to": "udev/99-lotus.rules"
      }
    ],
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "public/logo/lotus.ico",
      "signAndEditExecutable": true
    },
    "afterPack": "build/afterPack.js",
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "public/logo/lotus.png",
      "category": "Development",
      "synopsis": "Arduino-style IDE for Lotus robotics boards",
      "description": "Blockly + Arduino IDE for Lotus robotics boards (AVR, SAM, ESP32). Visual programming for K-12 + makers, with offline-bundled toolchain.",
      "executableName": "lotus-ide",
      "desktop": {
        "entry": {
          "Name": "Lotus IDE",
          "Comment": "Blockly + Arduino IDE for Lotus robotics boards",
          "GenericName": "Robotics IDE",
          "Keywords": "arduino;blockly;robotics;esp32;lotus;ide;education",
          "StartupWMClass": "Lotus IDE",
          "MimeType": "text/x-arduino;application/x-arduino-sketch"
        }
      }
    },
    "deb": {
      "afterInstall": "build/linux/after-install.sh",
      "afterRemove": "build/linux/after-remove.sh",
      "depends": [
        "libgtk-3-0",
        "libnotify4",
        "libnss3",
        "libxss1",
        "libxtst6",
        "xdg-utils",
        "libatspi2.0-0",
        "libdrm2",
        "libgbm1",
        "libsecret-1-0"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Lotus IDE",
      "differentialPackage": true,
      "include": "build/installer.nsh",
      "license": "build/license.txt"
    }
  }
}
